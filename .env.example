# App Settings
APP_NAME="Valura AI"
APP_VERSION="0.1.0"
DEBUG=True
ENVIRONMENT="development"

# LLM Settings
OPENAI_API_KEY=your_sk_key_here
OPENAI_MODEL="gpt-4o-mini"
LLM_TEMPERATURE=0.3

# Safety Settings
SAFETY_BLOCK_THRESHOLD=0.85
SAFETY_ENABLE_PROFANITY_CHECK=True

# Intent Classifier
INTENT_CONFIDENCE_THRESHOLD=0.6

# Streaming
SSE_HEARTBEAT_INTERVAL=15.0
